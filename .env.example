# ─────────────────────────────────────────────────────────────
#  Federation of Earth — environment configuration
# ─────────────────────────────────────────────────────────────

# Supabase (optional — landing & marketing pages work without it)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
DATABASE_URL=your-postgres-connection-string

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Governance thresholds
NEXT_PUBLIC_REFERENDUM_THRESHOLD_MIN=3
NEXT_PUBLIC_REFERENDUM_THRESHOLD_MAX=5
NEXT_PUBLIC_INITIATIVE_THRESHOLD=5
NEXT_PUBLIC_CAMPAIGN_DURATION_DAYS=30

# ─────────────────────────────────────────────────────────────
#  SMTP — membership applications are emailed to APPLICATIONS_INBOX.
#  If SMTP vars are blank, the API logs the email to stdout AND appends
#  it to .applications.jsonl so nothing is lost. Enable by setting at
#  least SMTP_HOST, SMTP_USER and SMTP_PASS.
# ─────────────────────────────────────────────────────────────
APPLICATIONS_INBOX=contact@fedearth.org
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="Federation of Earth <no-reply@fedearth.org>"
